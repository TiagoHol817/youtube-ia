// api/generate.js - Vercel Serverless Function
// Proxies requests to Whisk and Gemini to avoid CORS issues

module.exports = async function handler(req, res) {
  // Allow CORS from your app
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'POST, OPTIONS');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type');

  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const { type, prompt, aspectRatio, geminiKey, whiskToken } = req.body;

  // ── 1. EXPAND PROMPT with Gemini text ──────────────────────────────────────
  if (type === 'expand') {
    try {
      const model = 'gemini-2.5-flash';
      const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${geminiKey}`;
      const r = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          contents: [{ parts: [{ text: prompt }], role: 'user' }],
          generationConfig: { temperature: 1, topP: 0.95 }
        })
      });
      const data = await r.json();
      if (!r.ok) return res.status(r.status).json({ error: data.error?.message || 'Gemini text error' });
      const text = data.candidates?.[0]?.content?.parts?.[0]?.text?.trim();
      return res.status(200).json({ result: text });
    } catch (e) {
      return res.status(500).json({ error: e.message });
    }
  }

  // ── 2. GENERATE SCENES JSON with Gemini ────────────────────────────────────
  if (type === 'scenes') {
    try {
      const models = ['gemini-2.5-flash', 'gemini-2.0-flash'];
      let lastError = null;
      for (const model of models) {
        try {
          const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:generateContent?key=${geminiKey}`;
          const r = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              contents: [{ parts: [{ text: prompt }], role: 'user' }],
              generationConfig: {
                responseMimeType: 'application/json',
                responseSchema: {
                  type: 'ARRAY',
                  items: {
                    type: 'OBJECT',
                    properties: {
                      paragraph_index: { type: 'INTEGER' },
                      scenes: {
                        type: 'ARRAY',
                        items: {
                          type: 'OBJECT',
                          properties: {
                            script_segment: { type: 'STRING' },
                            visual_prompt: { type: 'STRING' }
                          },
                          required: ['script_segment', 'visual_prompt']
                        }
                      }
                    },
                    required: ['paragraph_index', 'scenes']
                  }
                }
              }
            })
          });
          const data = await r.json();
          if (!r.ok) { lastError = data.error?.message; continue; }
          const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
          return res.status(200).json({ result: JSON.parse(text) });
        } catch (e) { lastError = e.message; }
      }
      return res.status(500).json({ error: lastError || 'All Gemini models failed' });
    } catch (e) {
      return res.status(500).json({ error: e.message });
    }
  }

  // ── 3. GENERATE IMAGE with Whisk (CORS-free via server) ───────────────────
  if (type === 'image_whisk') {
    if (!whiskToken) return res.status(400).json({ error: 'No Whisk token' });
    const aspectMap = {
      '16:9': 'IMAGE_ASPECT_RATIO_LANDSCAPE',
      '9:16': 'IMAGE_ASPECT_RATIO_PORTRAIT',
      '1:1':  'IMAGE_ASPECT_RATIO_SQUARE'
    };

    // Try multiple Whisk endpoints
    const endpoints = [
      'https://aisandbox-pa.googleapis.com/v1:whisk',
      'https://labs.google/fx/api/v1/whisk:run'
    ];

    for (const endpoint of endpoints) {
      try {
        const r = await fetch(endpoint, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${whiskToken}`
          },
          body: JSON.stringify({
            imagePrompt: { parts: [{ text: prompt }] },
            imageStyle: { parts: [{ text: '' }] },
            generateImageConfig: {
              aspectRatio: aspectMap[aspectRatio] || 'IMAGE_ASPECT_RATIO_PORTRAIT',
              numberOfImages: 1
            }
          })
        });

        if (!r.ok) {
          console.log(`Whisk ${endpoint} status: ${r.status}`);
          continue;
        }

        const data = await r.json();
        const b64 = data.imageParts?.[0]?.imageUri?.split(',')[1]
          || data.images?.[0]?.bytesBase64Encoded
          || data.predictions?.[0]?.bytesBase64Encoded
          || data.generatedImages?.[0]?.image?.imageBytes;

        if (b64) return res.status(200).json({ image: `data:image/jpeg;base64,${b64}` });
      } catch (e) {
        console.log(`Whisk ${endpoint} error:`, e.message);
      }
    }
    return res.status(500).json({ error: 'All Whisk endpoints failed' });
  }

  // ── 4. GENERATE IMAGE with Gemini (imagen models) ─────────────────────────
  if (type === 'image_gemini') {
    if (!geminiKey) return res.status(400).json({ error: 'No Gemini key' });
    const models = [
      'gemini-2.0-flash-preview-image-generation',
      'imagen-3.0-generate-002',
      'imagen-3.0-fast-generate-001'
    ];
    for (const model of models) {
      try {
        const isImagen = model.startsWith('imagen');
        const url = `https://generativelanguage.googleapis.com/v1beta/models/${model}:${isImagen ? 'predict' : 'generateContent'}?key=${geminiKey}`;
        const body = isImagen
          ? { instances: [{ prompt }], parameters: { sampleCount: 1, aspectRatio: aspectRatio || '9:16' } }
          : {
              contents: [{ parts: [{ text: prompt }] }],
              generationConfig: { responseModalities: ['TEXT', 'IMAGE'] }
            };

        const r = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });

        if (!r.ok) { console.log(`Gemini image ${model} status: ${r.status}`); continue; }
        const data = await r.json();

        const b64 = isImagen
          ? data.predictions?.[0]?.bytesBase64Encoded
          : (data.candidates?.[0]?.content?.parts || []).find(p => p.inlineData)?.inlineData?.data;
        const mime = isImagen ? 'image/png'
          : (data.candidates?.[0]?.content?.parts || []).find(p => p.inlineData)?.inlineData?.mimeType || 'image/png';

        if (b64) return res.status(200).json({ image: `data:${mime};base64,${b64}` });
      } catch (e) {
        console.log(`Gemini image ${model} error:`, e.message);
      }
    }
    return res.status(500).json({ error: 'All Gemini image models failed' });
  }

  return res.status(400).json({ error: 'Unknown type' });
}
